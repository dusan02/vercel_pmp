{
    "buildCommand": "npm install && npm run build",
    "installCommand": "npm install --legacy-peer-deps",
    "framework": "nextjs",
    "functions": {
        "src/app/api/**/*.ts": {
            "maxDuration": 300
        }
    },
    "crons": [
        {
            "path": "/api/cron/post-market-reset",
            "schedule": "30 21 * * *"
        }
    ],
    "env": {
        "NODE_ENV": "production",
        "DATABASE_URL": "file:./dev.db",
        "TZ": "UTC"
    }
}