generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String           @id @default(cuid())
  name          String?
  email         String?          @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  favorites     UserFavorite[]
  portfolio     PortfolioItem[]
  preferences   UserPreferences?
}

model PortfolioItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticker    String
  quantity  Float
  avgPrice  Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tickerRef Ticker   @relation(fields: [ticker], references: [symbol], onDelete: Cascade)

  @@unique([userId, ticker])
  @@index([userId])
  @@index([ticker])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserPreferences {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  favorites       String
  theme           String   @default("auto")
  defaultTab      String   @default("all")
  autoRefresh     Boolean  @default(true)
  refreshInterval Int      @default(30)
  showEarnings    Boolean  @default(true)
  showNews        Boolean  @default(true)
  tableColumns    String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model EarningsCalendar {
  id                     String   @id @default(cuid())
  ticker                 String
  companyName            String
  date                   DateTime
  time                   String
  epsEstimate            Float?
  epsActual              Float?
  revenueEstimate        Float?
  revenueActual          Float?
  epsSurprisePercent     Float?
  revenueSurprisePercent Float?
  marketCap              Float?
  percentChange          Float?
  marketCapDiff          Float?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([ticker, date])
  @@index([date])
  @@index([ticker])
}

model Ticker {
  symbol              String    @id
  name                String?
  sector              String?
  industry            String?
  description         String?
  employees           Int?
  websiteUrl          String?
  logoUrl             String?
  sharesOutstanding   Float?
  adrRatio            Float?
  isAdr               Boolean   @default(false)
  latestPrevClose     Float?
  latestPrevCloseDate DateTime?

  // Cached values for efficient sorting (SQL-first architecture)
  lastPrice         Float?
  lastChangePct     Float?     // Should be bounded between -999.99 and 999.99
  lastMarketCap     Float?     // Should be in billions, bounded between 0 and 10000
  lastMarketCapDiff Float?     // Should be in billions, bounded between -10000 and 10000
  lastPriceUpdated  DateTime?

  // Movers Section Stats (calculated daily)
  avgVolume20d    Float?
  stdDevReturn20d Float?
  avgReturn20d    Float?

  // Real-time Movers Metrics
  latestMoversZScore Float?
  latestMoversRVOL   Float?
  moversReason       String?
  moversCategory     String? // e.g., 'Earnings', 'Guidance', 'M&A', 'Macro', 'Technical'
  socialCopy         String? // Catchy 160-char summary for social media
  isSbcAlert         Boolean @default(false)
  aiConfidence       Int? // 1-100 scale

  updatedAt     DateTime        @updatedAt
  dailyRefs     DailyRef[]
  sessionPrices SessionPrice[]
  moverEvents   MoverEvent[]
  volumeBuckets VolumeBucket[]
  userFavorites UserFavorite[]
  portfolio     PortfolioItem[]

  // Analysis module relations
  financialStatements FinancialStatement[]
  dailyValuations     DailyValuationHistory[]
  analysisCache       AnalysisCache?
  
  // Valuation charts relations
  valuationHistories   ValuationHistory[]
  valuationPercentiles ValuationPercentiles[]

  @@index([sector])
  @@index([sharesOutstanding])
  @@index([latestPrevCloseDate])
  @@index([lastPrice])
  @@index([lastChangePct])
  @@index([lastMarketCap])
  @@index([lastMarketCapDiff])
  @@index([sector, lastMarketCap])
  @@index([industry, lastMarketCap])
}

model MoverEvent {
  id        String   @id @default(cuid())
  symbol    String
  timestamp DateTime @default(now())
  date      DateTime // Trading day (for filtering)

  // Snapshot at detection
  priceAtEvent Float
  zScore       Float
  rvol         Float
  changePct    Float

  // AI Analysis (Link to Ticker or copy)
  category  String? // 'Earnings', 'Guidance', etc.
  reason    String?
  sentiment Float?

  // Follow-through (Performance Tracking)
  impact1h      Float? // % change after 1 hour
  impactEndDay  Float? // % change at market close
  impactNextDay Float? // % change at next day close

  ticker Ticker @relation(fields: [symbol], references: [symbol], onDelete: Cascade)

  @@index([date])
  @@index([category])
  @@index([symbol])
}

model DailyRef {
  id            String   @id @default(cuid())
  symbol        String
  date          DateTime
  previousClose Float
  todayOpen     Float?
  regularClose  Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  ticker        Ticker   @relation(fields: [symbol], references: [symbol], onDelete: Cascade)

  @@unique([symbol, date])
  @@index([date])
  @@index([symbol])
}

model SessionPrice {
  id        String   @id @default(cuid())
  symbol    String
  date      DateTime
  session   String
  lastPrice Float
  lastTs    DateTime
  changePct Float
  source    String
  quality   String

  // Movers data
  zScore Float?
  rvol   Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ticker    Ticker   @relation(fields: [symbol], references: [symbol], onDelete: Cascade)

  @@unique([symbol, date, session])
  @@index([date, session])
  @@index([symbol, session])
  @@index([lastTs])
  @@index([changePct])
}

model UserFavorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticker    String
  createdAt DateTime @default(now())
  tickerRef Ticker   @relation(fields: [ticker], references: [symbol], onDelete: Cascade)

  @@unique([userId, ticker])
  @@index([userId])
  @@index([ticker])
}

model VolumeBucket {
  id        String   @id @default(cuid())
  symbol    String
  bucket    String // e.g., "09:30", "09:45"
  avgVolume Float // Average cumulative volume at this time
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ticker    Ticker   @relation(fields: [symbol], references: [symbol], onDelete: Cascade)

  @@unique([symbol, bucket])
  @@index([symbol])
}

model FinancialStatement {
  id           String   @id @default(cuid())
  symbol       String
  period       String // e.g., 'FY', 'Q1', 'Q2', etc. (Polygon calendar)
  endDate      DateTime
  fiscalYear   Int
  fiscalPeriod String // e.g., 'FY', 'Q1'

  // Income Statement
  revenue      Float?
  netIncome    Float?
  ebit         Float?
  grossProfit  Float?

  // Cash Flow
  operatingCashFlow Float?
  capex             Float?

  // Balance Sheet
  totalAssets        Float?
  totalLiabilities   Float?
  currentAssets      Float?
  currentLiabilities Float?
  retainedEarnings   Float?
  totalEquity        Float?

  // Other standard fields
  sharesOutstanding  Float?
  sbc                Float? // Stock-based compensation
  interestExpense    Float?
  totalDebt          Float?
  cashAndEquivalents Float?
  netPPE             Float? // Net Property, Plant & Equipment

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticker Ticker @relation(fields: [symbol], references: [symbol], onDelete: Cascade)

  @@unique([symbol, fiscalYear, fiscalPeriod])
  @@index([symbol])
  @@index([fiscalYear, fiscalPeriod])
  @@index([endDate])
}

model DailyValuationHistory {
  id     String   @id @default(cuid())
  symbol String
  date   DateTime

  closePrice Float?
  marketCap  Float?

  // Basic valuation ratios
  peRatio  Float?
  psRatio  Float?
  pbRatio  Float?        // NEW: Price/Book Value
  evEbitda Float?
  fcfYield Float?

  // GuruFocus style ratios
  evRevenue    Float?    // NEW: EV/Revenue
  evFcf        Float?    // NEW: EV/Free Cash Flow
  priceTangibleBook Float? // NEW: Price/Tangible Book
  pegRatio     Float?    // NEW: PEG Ratio (P/E / Growth)
  dividendYield Float?   // NEW: Dividend Yield

  // Additional metrics for GuruFocus
  roic         Float?    // NEW: Return on Invested Capital
  roe          Float?    // NEW: Return on Equity
  debtToEquity Float?    // NEW: Debt/Equity Ratio
  currentRatio  Float?   // NEW: Current Ratio
  quickRatio    Float?   // NEW: Quick Ratio

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticker Ticker @relation(fields: [symbol], references: [symbol], onDelete: Cascade)

  // Combined index for huge table
  @@unique([symbol, date])
  // Allow efficient lookup by date or by symbol separately
  @@index([symbol])
  @@index([date])
  @@index([symbol, date, peRatio])
  @@index([symbol, date, pbRatio])
}

model AnalysisCache {
  id     String @id @default(cuid())
  symbol String @unique

  healthScore        Float? // 0-100
  profitabilityScore Float? // 0-100
  valuationScore     Float? // 0-100
  verdictText        String? // AI Verdict

  // Deep-Dive Metrics
  piotroskiScore    Int?    // 0-9
  beneishScore      Float?  // < -1.78 = no manipulation
  interestCoverage  Float?  // EBIT / Interest Expense
  revenueCagr       Float?  // 5Y Revenue CAGR (%)
  netIncomeCagr     Float?  // 5Y Net Income CAGR (%)

  // NEW: Advanced Metrics
  altmanZ           Float?
  debtRepaymentYears Float? // Net Debt / FCF
  fcfMargin         Float?
  fcfConversion     Float? // FCF / Net Income
  
  // NEW: Interpretations
  humanDebtInfo     String? // e.g. "Firma potrebuje 4.2 roka na splatenie dlhu."
  humanPeInfo       String? // e.g. "Aktuálne PE je v horných 15% poslednej dekády."
  
  // NEW: Quality Stats
  marginStability   Float? 
  negativeNiYears   Int?   

  lastQualitySignalAt DateTime? // NEW: Track when it hits Safe Zone + High Health

  updatedAt DateTime @updatedAt

  ticker Ticker @relation(fields: [symbol], references: [symbol], onDelete: Cascade)

  @@index([healthScore])
  @@index([valuationScore])
}

model Subscription {
  id        String   @id @default(cuid())
  symbol    String?  // Optional: subscribe to specific ticker
  endpoint  String   @unique
  p256dh    String
  auth      String
  email     String?  // Optional: e-mail subscription
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ValuationHistory {
  id          String   @id @default(cuid())
  symbol      String
  date        DateTime
  metric      String   // 'pe_ratio', 'pb_ratio', 'ps_ratio', 'ev_ebitda'
  value       Float
  percentile  Float?   // Vypočítaný percentil v kontexte obdobia
  period      String   // 'monthly', 'daily'
  createdAt   DateTime @default(now())
  
  ticker Ticker @relation(fields: [symbol], references: [symbol], onDelete: Cascade)
  
  @@unique([symbol, date, metric, period])
  @@index([symbol, date])
  @@index([date])
  @@index([symbol, metric])
}

model ValuationPercentiles {
  id          String   @id @default(cuid())
  symbol      String
  metric      String
  period      String   // '10y', '5y', '1y', '6m', '3m', '1m'
  p10         Float    // 10th percentile
  p25         Float    // 25th percentile
  p50         Float    // 50th percentile (median)
  p75         Float    // 75th percentile
  p90         Float    // 90th percentile
  mean        Float
  stdDev      Float
  sampleSize  Int
  lastUpdated DateTime @default(now())
  
  ticker Ticker @relation(fields: [symbol], references: [symbol], onDelete: Cascade)
  
  @@unique([symbol, metric, period])
  @@index([symbol, metric])
}
